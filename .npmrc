# Fail install if the current Node/npm version doesn't satisfy engines fields in package.json
engine-strict=true
# Pin exact versions in package.json instead of using semver ranges (e.g. "1.2.3" not "^1.2.3")
save-exact=true
# Fail install if there are unresolved peer dependency conflicts instead of auto-resolving
strict-peer-deps=true
# Only allow packages that have been published for at least 30 days (reduces supply-chain risk from malicious new releases)
min-release-age=30
# Run npm audit automatically on install to flag known vulnerabilities
audit=true
